# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=

# JWT
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Client URL (CORS origin)
CLIENT_URL=http://localhost:5173

# Google Gemini AI (optional — AI features disabled without it)
GEMINI_API_KEY=

# Email / SMTP (optional — runs in preview mode when unconfigured)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
